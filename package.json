{
  "name": "local-ai-classifier-client",
  "version": "0.2.0",
  "description": "Local host agent for Local AI Classifier Router and Ollama.",
  "type": "module",
  "main": "dist/src/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/main.js",
    "classification:baseline": "tsx scripts/classification-baseline.ts",
    "deploy:preflight": "tsx scripts/run-deploy-preflight.ts",
    "deploy:install-service": "tsx scripts/run-deploy-install-service.ts",
    "deploy:service-status": "tsx scripts/run-deploy-service-status.ts",
    "deploy:reports": "tsx scripts/run-deploy-reports.ts",
    "deploy:autodeploy": "scripts/autodeploy.sh",
    "production:readiness": "tsx scripts/run-production-readiness.ts",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:local-ollama": "vitest run tests/integration/local-ollama.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/igorip2005/local-ai-classifier-client.git"
  },
  "keywords": [
    "ollama",
    "websocket",
    "telemetry",
    "classifier",
    "host-agent"
  ],
  "author": "Igor / KLO4",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/igorip2005/local-ai-classifier-client/issues"
  },
  "homepage": "https://github.com/igorip2005/local-ai-classifier-client#readme",
  "dependencies": {
    "dotenv": "^17.2.3",
    "pino": "^10.1.0",
    "uuid": "^13.0.0",
    "ws": "^8.18.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
