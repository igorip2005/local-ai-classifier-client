# Local AI Classifier Client environment example.
# Copy to .env on each host and set ROUTER_URL plus SETUP_TOKEN for first registration.
# Business contract: router doc/IMPLEMENTATION_DETAILS.md sections 5, 7, 15, 20, 21, 24 and 27.

# Local development defaults. For production, set NODE_ENV=production and replace
# ROUTER_URL, CLIENT_NAME and CLIENT_BUILD_ID with deployment-specific values.
NODE_ENV=development
ROUTER_URL=ws://127.0.0.1:3100/v1/hosts/connect
SETUP_TOKEN=
OLLAMA_BASE_URL=http://127.0.0.1:11434

CLIENT_NAME=local-test-client
CLIENT_BUILD_ID=dev
CLIENT_LOCAL_LOG_MODE=none
CLIENT_MAX_CONCURRENT_TASKS=1
CLIENT_ALLOW_MODEL_PULL=false
CLIENT_MANUAL_ENABLED=true
CLIENT_FAST_HEARTBEAT_MS=5000
CLIENT_FULL_HEARTBEAT_MS=15000
CLIENT_DATA_DIR=/www/projects/local-ai-classifier-client/var
CLIENT_STATUS_PORT=0

# Internal trusted-host deploy loop. Keep disabled unless the host is trusted.
# By default, trusted deploy runs scripts/autodeploy.sh, which pulls git, checks
# the client, rebuilds it and schedules a local service restart.
CLIENT_DEPLOY_ENABLED=false
CLIENT_DEPLOY_COMMAND=/www/projects/local-ai-classifier-client/scripts/autodeploy.sh
CLIENT_DEPLOY_TIMEOUT_MS=120000

LOG_LEVEL=info
