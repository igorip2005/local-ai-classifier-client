# HTTP server
PORT=3088
HOST=0.0.0.0

# Ollama endpoint reachable on localhost/LAN/Tailscale
OLLAMA_BASE_URL=http://127.0.0.1:11434
DEFAULT_MODEL=qwen3:1.7b
DEFAULT_THINK=false
DEFAULT_STREAM=false
REQUEST_TIMEOUT_MS=120000

# PostgreSQL
DATABASE_URL=postgres://local_ai_classifier:local_ai_classifier@127.0.0.1:5432/local_ai_classifier

# Optional API key for this wrapper. Leave empty to allow LAN/Tailscale clients.
API_KEY=

# Metrics
NVIDIA_SMI_PATH=/usr/lib/wsl/lib/nvidia-smi
LOG_FULL_BODIES=true
